# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://hemaweb:hemaweb@localhost:5432/hemaweb

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT & Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Swagger
SWAGGER_ENABLED=true

# Email (optional - uses ethereal.email if not configured)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM="HemaWeb" <noreply@hemaweb.world>

