{
  "name": "@hemaweb/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma database schema and client for HemaWeb",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:create": "prisma migrate dev --create-only",
    "migrate:reset": "prisma migrate reset",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@hemaweb/config": "workspace:*",
    "@types/node": "^22.10.0",
    "prisma": "^6.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}

