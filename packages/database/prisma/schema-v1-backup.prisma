// HemaWeb Database Schema
// Based on ER diagram from docs/data_model.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================================================
// DONOR ACCOUNTS & PROFILES
// ============================================================================

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hashed
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile              Profile?
  verificationRecords  VerificationRecord[]
  donationRecords      DonationRecord[]
  sessions             Session[]
  notifications        Notification[]
  suspensionLog        SuspensionLog[]

  @@map("accounts")
}

model Profile {
  id                String             @id @default(cuid())
  accountId         String             @unique
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  bloodType         BloodType?
  isVerified        Boolean            @default(false)
  availabilityStatus AvailabilityStatus @default(UNAVAILABLE)
  location          Unsupported("geography(Point, 4326)")? // PostGIS geography type
  lastDonationDate  DateTime?
  nextEligibleDate  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================================================
// MEDICAL ORGANIZATIONS & CENTERS
// ============================================================================

model MedicalOrganization {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  medicalCenters MedicalCenter[]
  superAdmins    MedicalCenterAccount[] @relation("OrganizationSuperAdmins")

  @@map("medical_organizations")
}

model MedicalCenter {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String
  location       Unsupported("geography(Point, 4326)")? // PostGIS geography type
  phone          String?
  email          String?
  logoUrl        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization        MedicalOrganization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staff               MedicalCenterAccount[]
  bloodDrives         BloodDrive[]
  verificationRecords VerificationRecord[]
  donationRecords     DonationRecord[]

  @@map("medical_centers")
}

// ============================================================================
// MEDICAL CENTER PERSONNEL
// ============================================================================

model MedicalCenterAccount {
  id             String                  @id @default(cuid())
  email          String                  @unique
  password       String // hashed
  firstName      String
  lastName       String
  role           MedicalCenterRole
  medicalCenterId String?
  organizationId String?
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  // Relations
  medicalCenter       MedicalCenter?       @relation(fields: [medicalCenterId], references: [id], onDelete: SetNull)
  organization        MedicalOrganization? @relation("OrganizationSuperAdmins", fields: [organizationId], references: [id], onDelete: SetNull)
  activityLogs        ActivityLog[]
  sessions            Session[]
  verificationRecords VerificationRecord[]
  donationRecords     DonationRecord[]
  bloodDrives         BloodDrive[]

  @@map("medical_center_accounts")
}

enum MedicalCenterRole {
  STAFF
  ADMIN
  SUPER_ADMIN
}

// ============================================================================
// BLOOD DRIVES
// ============================================================================

model BloodDrive {
  id              String           @id @default(cuid())
  medicalCenterId String
  createdById     String
  type            BloodDriveType
  status          BloodDriveStatus @default(UPCOMING)
  title           String
  description     String?
  location        Unsupported("geography(Point, 4326)")? // PostGIS geography type
  address         String?
  bloodTypesNeeded BloodType[]
  startDateTime   DateTime
  endDateTime     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  medicalCenter MedicalCenter        @relation(fields: [medicalCenterId], references: [id], onDelete: Cascade)
  createdBy     MedicalCenterAccount @relation(fields: [createdById], references: [id])

  @@map("blood_drives")
}

enum BloodDriveType {
  SCHEDULED
  EMERGENCY
}

enum BloodDriveStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

// ============================================================================
// DONATION & VERIFICATION RECORDS
// ============================================================================

model DonationRecord {
  id              String   @id @default(cuid())
  accountId       String
  medicalCenterId String
  recordedById    String
  donationDate    DateTime
  bloodType       BloodType
  volumeMl        Int
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  account       Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  medicalCenter MedicalCenter        @relation(fields: [medicalCenterId], references: [id])
  recordedBy    MedicalCenterAccount @relation(fields: [recordedById], references: [id])

  @@map("donation_records")
}

model VerificationRecord {
  id              String   @id @default(cuid())
  accountId       String
  medicalCenterId String
  verifiedById    String
  bloodType       BloodType
  isEligible      Boolean
  certificateUrl  String? // S3 URL or local file path
  notes           String?
  verifiedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  account       Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  medicalCenter MedicalCenter        @relation(fields: [medicalCenterId], references: [id])
  verifiedBy    MedicalCenterAccount @relation(fields: [verifiedById], references: [id])

  @@map("verification_records")
}

// ============================================================================
// ACTIVITY LOGS
// ============================================================================

model ActivityLog {
  id        String   @id @default(cuid())
  accountId String
  action    String
  entityType String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  // Relations
  account MedicalCenterAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// ============================================================================
// SYSTEM ADMIN ACCOUNTS
// ============================================================================

model SystemAdminAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hashed
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions          Session[]
  informationRecords InformationRecord[]

  @@map("system_admin_accounts")
}

// ============================================================================
// INFORMATIONAL CONTENT
// ============================================================================

model InformationRecord {
  id          String   @id @default(cuid())
  createdById String
  title       String
  content     String // Markdown or HTML
  category    String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdBy SystemAdminAccount @relation(fields: [createdById], references: [id])

  @@map("information_records")
}

// ============================================================================
// AUTHENTICATION & SESSIONS (Lucia Auth)
// ============================================================================

model Session {
  id        String   @id
  userId    String
  userType  UserType
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations (polymorphic)
  donorAccount         Account?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicalCenterAccount MedicalCenterAccount? @relation(fields: [userId], references: [id], onDelete: Cascade)
  systemAdminAccount   SystemAdminAccount?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserType {
  DONOR
  MEDICAL_CENTER_STAFF
  SYSTEM_ADMIN
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id        String           @id @default(cuid())
  accountId String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  readAt    DateTime?

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  BLOOD_DRIVE_ALERT
  DONATION_CONFIRMATION
  VERIFICATION_COMPLETE
  COOLDOWN_REMINDER
  GENERAL
}

// ============================================================================
// USER SUSPENSION LOGS
// ============================================================================

model SuspensionLog {
  id          String    @id @default(cuid())
  accountId   String
  suspendedBy String // System Admin ID
  reason      String
  suspendedAt DateTime  @default(now())
  unsuspendedAt DateTime?
  isActive    Boolean   @default(true)

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("suspension_logs")
}

// ============================================================================
// ENUMS
// ============================================================================

enum BloodType {
  A_POSITIVE  @map("A+")
  A_NEGATIVE  @map("A-")
  B_POSITIVE  @map("B+")
  B_NEGATIVE  @map("B-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  O_POSITIVE  @map("O+")
  O_NEGATIVE  @map("O-")
}

enum AvailabilityStatus {
  AVAILABLE
  EMERGENCIES_ONLY
  UNAVAILABLE
}
