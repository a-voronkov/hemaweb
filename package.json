{
  "name": "hemaweb",
  "version": "0.1.0",
  "private": true,
  "description": "HemaWeb - Blood Donation Platform connecting hospitals with verified donors",
  "keywords": [
    "blood-donation",
    "healthcare",
    "nextjs",
    "nestjs",
    "monorepo"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @hemaweb/database migrate",
    "db:migrate:dev": "pnpm --filter @hemaweb/database migrate:dev",
    "db:seed": "pnpm --filter @hemaweb/database seed",
    "db:studio": "pnpm --filter @hemaweb/database studio",
    "db:reset": "pnpm --filter @hemaweb/database reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "turbo": "^1.11.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

