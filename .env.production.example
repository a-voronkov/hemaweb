# Production Environment Variables
# Copy this to .env on the server and fill in the values

# Application
NODE_ENV=production

# Frontend
NEXT_PUBLIC_API_URL=https://hemaweb.world/api
NEXT_PUBLIC_APP_NAME=HemaWeb
NEXT_PUBLIC_APP_URL=https://hemaweb.world

# Backend
FRONTEND_URL=https://hemaweb.world
CORS_ORIGIN=https://hemaweb.world

# Database
DATABASE_URL=postgresql://hemaweb:hemaweb_password_2024@postgres:5432/hemaweb

# Redis
REDIS_PASSWORD=hemaweb_redis_password

# JWT & Auth
JWT_SECRET=your-production-secret-key-change-this
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Email - Mailjet API
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
EMAIL_FROM=noreply@hemaweb.world
EMAIL_FROM_NAME=HemaWeb

