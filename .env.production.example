# Production Environment Variables
# Copy this to .env on the server and fill in the values

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_USER=hemaweb
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=hemaweb
DATABASE_URL=postgresql://hemaweb:CHANGE_ME_SECURE_PASSWORD@postgres:5432/hemaweb

# ============================================================================
# REDIS
# ============================================================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://redis:6379

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=production
PORT=3001

# ============================================================================
# CORS & FRONTEND
# ============================================================================
CORS_ORIGIN=https://hemaweb.world
FRONTEND_URL=https://hemaweb.world
NEXT_PUBLIC_API_URL=https://hemaweb.world/api
NEXT_PUBLIC_APP_URL=https://hemaweb.world
NEXT_PUBLIC_APP_NAME=HemaWeb

# ============================================================================
# EMAIL (Mailjet)
# ============================================================================
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_SENDER_EMAIL=noreply@hemaweb.world
MAILJET_SENDER_NAME=HemaWeb
